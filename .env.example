# TMDb Read Access Token (Bearer) — get one at https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=your_token_here

# SearchApi.io — Google Images engine — get one at https://www.searchapi.io
SEARCHAPI_KEY=your_searchapi_key_here

# Exa neural search — profile & asset image enrichment — get one at https://exa.ai
EXA_API_KEY=your_exa_key_here
